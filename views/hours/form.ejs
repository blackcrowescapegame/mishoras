<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h2 class="fw-bold mb-4">
          <i class="bi bi-clock-history me-2 text-primary"></i>
          <%= title %>
        </h2>

        <%- include('../partials/alerts') %>

        <form method="POST"
              action="<%= entry ? '/hours/' + entry.id + '?_method=PUT' : '/hours' %>"
              novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <!-- Entry mode tabs (only on new entry) -->
          <% if (!entry) { %>
          <div class="mb-3">
            <label class="form-label fw-semibold">Modo de entrada</label>
            <div class="btn-group w-100" role="group">
              <input type="radio" class="btn-check" name="entry_mode" id="modeDay" value="day" checked />
              <label class="btn btn-outline-primary" for="modeDay">
                <i class="bi bi-calendar-day me-1"></i>Por día
              </label>
              <input type="radio" class="btn-check" name="entry_mode" id="modeQty" value="quantity" />
              <label class="btn btn-outline-primary" for="modeQty">
                <i class="bi bi-123 me-1"></i>Por cantidad
              </label>
            </div>
          </div>
          <% } %>

          <!-- Date (shown for "day" mode) -->
          <div class="mb-3" id="dateField">
            <label for="entry_date" class="form-label fw-semibold">Fecha</label>
            <input type="date" id="entry_date" name="entry_date" class="form-control"
                   value="<%= entry ? new Date(entry.entry_date).toISOString().slice(0,10) : new Date().toISOString().slice(0,10) %>"
                   required />
          </div>

          <!-- Project -->
          <div class="mb-3">
            <label for="project_id" class="form-label fw-semibold">Proyecto <span class="text-danger">*</span></label>
            <select id="project_id" name="project_id" class="form-select" required>
              <option value="">-- Seleccionar proyecto --</option>
              <%
                const groupedProjects = {};
                projects.forEach(p => {
                  if (!groupedProjects[p.client_name]) groupedProjects[p.client_name] = [];
                  groupedProjects[p.client_name].push(p);
                });
                Object.keys(groupedProjects).forEach(clientName => {
              %>
              <optgroup label="<%= clientName %>">
                <% groupedProjects[clientName].forEach(p => { %>
                <option value="<%= p.id %>" <%= (entry && entry.project_id === p.id) ? 'selected' : '' %>><%= p.client_name %> - <%= p.name %></option>
                <% }); %>
              </optgroup>
              <% }); %>
            </select>
          </div>

          <!-- Task (loaded via AJAX) -->
          <div class="mb-3">
            <label for="task_id" class="form-label fw-semibold">Tarea <span class="text-muted small">(opcional)</span></label>
            <select id="task_id" name="task_id" class="form-select">
              <option value="">-- Seleccionar tarea (opcional) --</option>
              <% tasks.forEach(t => { %>
              <option value="<%= t.id %>" <%= (entry && entry.task_id === t.id) ? 'selected' : '' %>>
                <%= t.name %>
              </option>
              <% }) %>
            </select>
          </div>

          <!-- Hours -->
          <div class="mb-3">
            <label for="hours" class="form-label fw-semibold">Horas <span class="text-danger">*</span></label>
            <div class="input-group">
              <input type="text" id="hours" name="hours" class="form-control"
                     value="<%= entry ? (function(h){ const t=Math.round(parseFloat(h)*60); return Math.floor(t/60)+':'+String(t%60).padStart(2,'0'); })(entry.hours) : '' %>"
                     placeholder="ej. 1:30 ó 0130" required autocomplete="off" />
              <span class="input-group-text">h</span>
            </div>
            <div class="form-text">Formato HH:MM (1:30) o HHMM sin dos puntos (0130 = 1h 30m, 0030 = 30 min)</div>
          </div>

          <!-- Description -->
          <div class="mb-4">
            <label for="description" class="form-label fw-semibold">Descripción</label>
            <textarea id="description" name="description" class="form-control" rows="3"
                      placeholder="¿En qué trabajaste?"><%= entry ? entry.description || '' : '' %></textarea>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-floppy me-1"></i><%= entry ? 'Guardar cambios' : 'Registrar horas' %>
            </button>
            <a href="/hours" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const projectSel = document.getElementById('project_id');
  const taskSel    = document.getElementById('task_id');
  const dateField  = document.getElementById('dateField');
  const modeDay    = document.getElementById('modeDay');
  const modeQty    = document.getElementById('modeQty');
  const hoursInput = document.getElementById('hours');

  // Convert HHMM/HH:MM to decimal before submit
  function parseHoursInput(str) {
    if (!str || !str.trim()) return 0;
    const s = str.trim();
    if (s.includes(':')) {
      const parts = s.split(':');
      return (parseInt(parts[0], 10) || 0) + (parseInt(parts[1], 10) || 0) / 60;
    }
    if (/^\d{3,}$/.test(s)) {
      const mm = parseInt(s.slice(-2), 10) || 0;
      const hh = parseInt(s.slice(0, -2), 10) || 0;
      return hh + mm / 60;
    }
    return parseFloat(s) || 0;
  }

  document.querySelector('form').addEventListener('submit', function (e) {
    const dec = parseHoursInput(hoursInput.value);
    if (isNaN(dec) || dec <= 0) {
      e.preventDefault();
      hoursInput.classList.add('is-invalid');
      hoursInput.focus();
      return;
    }
    hoursInput.classList.remove('is-invalid');
    hoursInput.value = dec.toFixed(4);
  });

  // Toggle date visibility for quantity mode
  if (modeDay && modeQty) {
    function toggleDate() {
      dateField.style.display = modeQty && modeQty.checked ? 'none' : '';
    }
    modeDay.addEventListener('change', toggleDate);
    modeQty.addEventListener('change', toggleDate);
  }

  // Load tasks when project changes
  projectSel.addEventListener('change', async function () {
    const pid = this.value;
    taskSel.innerHTML = '<option value="">Loading…</option>';
    if (!pid) { taskSel.innerHTML = '<option value="">-- Select task (optional) --</option>'; return; }
    try {
      const res  = await fetch('/hours/api/tasks/' + pid);
      const data = await res.json();
      taskSel.innerHTML = '<option value="">-- Select task (optional) --</option>' +
        data.map(t => `<option value="${t.id}">${t.name}</option>`).join('');
    } catch (e) {
      taskSel.innerHTML = '<option value="">-- Select task (optional) --</option>';
    }
  });
}());
</script>

<%- include('../partials/footer') %>
