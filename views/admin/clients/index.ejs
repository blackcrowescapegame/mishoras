<%- include('../../../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-building me-2 text-success"></i>Clients</h2>
  <a href="/admin/clients/new" class="btn btn-primary">
    <i class="bi bi-plus-circle me-1"></i>New Client
  </a>
</div>

<%- include('../../../partials/alerts') %>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>#</th><th>Name</th><th>Description</th><th>Status</th>
          <th>Created</th><th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% clients.forEach(c => { %>
        <tr>
          <td class="text-muted small"><%= c.id %></td>
          <td><%= c.name %></td>
          <td class="text-muted small text-truncate" style="max-width:250px"><%= c.description || '—' %></td>
          <td>
            <span class="badge <%= c.active ? 'bg-success' : 'bg-secondary' %>">
              <%= c.active ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td class="small text-muted"><%= new Date(c.created_at).toLocaleDateString() %></td>
          <td class="text-center text-nowrap">
            <a href="/admin/clients/<%= c.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
              <i class="bi bi-pencil"></i>
            </a>
            <form action="/admin/clients/<%= c.id %>?_method=DELETE" method="POST" class="d-inline"
                  onsubmit="return confirm('Deactivate this client?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
              <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!clients.length) { %>
        <tr><td colspan="6" class="text-center text-muted py-4">No clients found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../../../partials/footer') %>
