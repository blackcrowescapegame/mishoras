<%- include('../../../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h2 class="fw-bold mb-4">
          <i class="bi bi-person me-2 text-primary"></i><%= title %>
        </h2>

        <%- include('../../../partials/alerts') %>

        <form method="POST"
              action="<%= item ? '/admin/users/' + item.id + '?_method=PUT' : '/admin/users' %>"
              novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="mb-3">
            <label for="name" class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
            <input type="text" id="name" name="name" class="form-control"
                   value="<%= item ? item.name : '' %>" required />
          </div>

          <div class="mb-3">
            <label for="email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input type="email" id="email" name="email" class="form-control"
                   value="<%= item ? item.email : '' %>" required />
          </div>

          <div class="mb-3">
            <label for="password" class="form-label fw-semibold">
              Password <% if (item) { %><span class="text-muted small">(leave blank to keep current)</span><% } else { %><span class="text-danger">*</span><% } %>
            </label>
            <input type="password" id="password" name="password" class="form-control"
                   <%= !item ? 'required' : '' %> autocomplete="new-password" />
          </div>

          <div class="mb-3">
            <label for="role" class="form-label fw-semibold">Role <span class="text-danger">*</span></label>
            <select id="role" name="role" class="form-select" required>
              <option value="user"  <%= (!item || item.role === 'user')  ? 'selected' : '' %>>User</option>
              <option value="admin" <%= (item && item.role === 'admin')  ? 'selected' : '' %>>Admin</option>
            </select>
          </div>

          <% if (item) { %>
          <div class="mb-4">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="active" name="active"
                     value="1" <%= item.active ? 'checked' : '' %> />
              <label class="form-check-label" for="active">Active</label>
            </div>
          </div>
          <% } %>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-floppy me-1"></i><%= item ? 'Save changes' : 'Create user' %>
            </button>
            <a href="/admin/users" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../../../partials/footer') %>
