<%- include('../../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-body p-4">
        <h2 class="fw-bold mb-4">
          <i class="bi bi-person me-2 text-primary"></i><%= title %>
        </h2>

        <%- include('../../partials/alerts') %>

        <form method="POST"
              action="<%= item ? '/admin/users/' + item.id + '?_method=PUT' : '/admin/users' %>"
              novalidate>
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

          <div class="row mb-3">
            <div class="col-sm-8">
              <label for="name" class="form-label fw-semibold">Nombre <span class="text-danger">*</span></label>
              <input type="text" id="name" name="name" class="form-control"
                     value="<%= item ? item.name : '' %>" required />
            </div>
            <div class="col-sm-4">
              <label for="custom_id" class="form-label fw-semibold">ID personalizado</label>
              <input type="text" id="custom_id" name="custom_id" class="form-control"
                     value="<%= item ? item.custom_id || '' : '' %>" />
            </div>
          </div>

          <div class="mb-3">
            <label for="email" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input type="email" id="email" name="email" class="form-control"
                   value="<%= item ? item.email : '' %>" required />
          </div>

          <div class="mb-3">
            <label for="password" class="form-label fw-semibold">
              Contraseña <% if (item) { %><span class="text-muted small">(dejar en blanco para conservar)</span><% } else { %><span class="text-danger">*</span><% } %>
            </label>
            <input type="password" id="password" name="password" class="form-control"
                   <%= !item ? 'required' : '' %> autocomplete="new-password" />
            <% if (!item) { %>
            <div class="form-text">Los usuarios importados desde Excel reciben la contraseña <strong>MisHoras123</strong> por defecto.</div>
            <% } %>
          </div>

          <div class="row mb-3">
            <div class="col-sm-6">
              <label for="role" class="form-label fw-semibold">Rol <span class="text-danger">*</span></label>
              <select id="role" name="role" class="form-select" required>
                <option value="user"  <%= (!item || item.role === 'user')  ? 'selected' : '' %>>Usuario</option>
                <option value="admin" <%= (item && item.role === 'admin')  ? 'selected' : '' %>>Admin</option>
              </select>
            </div>
            <div class="col-sm-3">
              <label for="labor_rate" class="form-label fw-semibold">Tarifa laboral</label>
              <input type="number" id="labor_rate" name="labor_rate" class="form-control"
                     min="0" step="0.01" value="<%= item && item.labor_rate != null ? item.labor_rate : '' %>" />
            </div>
            <div class="col-sm-3">
              <label for="billable_rate" class="form-label fw-semibold">Tarifa facturable</label>
              <input type="number" id="billable_rate" name="billable_rate" class="form-control"
                     min="0" step="0.01" value="<%= item && item.billable_rate != null ? item.billable_rate : '' %>" />
            </div>
          </div>

          <% if (item) { %>
          <div class="mb-3">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" id="active" name="active"
                     value="1" <%= item.active ? 'checked' : '' %> />
              <label class="form-check-label" for="active">Activo</label>
            </div>
          </div>
          <% } %>

          <!-- Project assignments -->
          <div class="mb-4">
            <label class="form-label fw-semibold">Proyectos asignados</label>
            <div class="border rounded p-2" style="max-height:220px;overflow-y:auto">
              <% if (!allProjects.length) { %>
                <p class="text-muted small mb-0">No hay proyectos activos.</p>
              <% } %>
              <% let lastClient = null; %>
              <% allProjects.forEach(p => { %>
                <% if (p.client_name !== lastClient) { lastClient = p.client_name; %>
                <div class="text-muted small fw-bold mt-2 mb-1 px-1"><%= p.client_name %></div>
                <% } %>
                <div class="form-check ms-2">
                  <input class="form-check-input" type="checkbox" name="project_ids"
                         id="proj_<%= p.id %>" value="<%= p.id %>"
                         <%= assignedIds.includes(p.id) ? 'checked' : '' %> />
                  <label class="form-check-label small" for="proj_<%= p.id %>"><%= p.name %></label>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-floppy me-1"></i><%= item ? 'Guardar cambios' : 'Crear usuario' %>
            </button>
            <a href="/admin/users" class="btn btn-outline-secondary">Cancelar</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/footer') %>
