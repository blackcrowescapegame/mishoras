<%- include('../../../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="fw-bold mb-0"><i class="bi bi-kanban me-2 text-warning"></i>Projects</h2>
  <a href="/admin/projects/new" class="btn btn-primary">
    <i class="bi bi-plus-circle me-1"></i>New Project
  </a>
</div>

<%- include('../../../partials/alerts') %>

<div class="card border-0 shadow-sm">
  <div class="table-responsive">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>#</th><th>Name</th><th>Client</th><th>Description</th><th>Status</th>
          <th>Created</th><th class="text-center">Actions</th>
        </tr>
      </thead>
      <tbody>
        <% projects.forEach(p => { %>
        <tr>
          <td class="text-muted small"><%= p.id %></td>
          <td><%= p.name %></td>
          <td><span class="badge bg-secondary-subtle text-secondary"><%= p.client_name %></span></td>
          <td class="text-muted small text-truncate" style="max-width:200px"><%= p.description || '—' %></td>
          <td>
            <span class="badge <%= p.active ? 'bg-success' : 'bg-secondary' %>">
              <%= p.active ? 'Active' : 'Inactive' %>
            </span>
          </td>
          <td class="small text-muted"><%= new Date(p.created_at).toLocaleDateString() %></td>
          <td class="text-center text-nowrap">
            <a href="/admin/projects/<%= p.id %>/edit" class="btn btn-sm btn-outline-secondary me-1">
              <i class="bi bi-pencil"></i>
            </a>
            <form action="/admin/projects/<%= p.id %>?_method=DELETE" method="POST" class="d-inline"
                  onsubmit="return confirm('Deactivate this project?')">
              <button type="submit" class="btn btn-sm btn-outline-danger">
                <i class="bi bi-trash"></i>
              </button>
            </form>
          </td>
        </tr>
        <% }) %>
        <% if (!projects.length) { %>
        <tr><td colspan="7" class="text-center text-muted py-4">No projects found.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../../../partials/footer') %>
