<%- include('../../partials/header') %>

<h2 class="fw-bold mb-4"><i class="bi bi-bar-chart me-2 text-danger"></i>Reports</h2>

<%- include('../../partials/alerts') %>

<!-- Filters -->
<div class="card border-0 shadow-sm mb-4">
  <div class="card-body">
    <form method="GET" action="/admin/reports" class="row g-3 align-items-end">
      <div class="col-sm-3">
        <label class="form-label small fw-semibold">From</label>
        <input type="date" name="from" class="form-control" value="<%= from %>" />
      </div>
      <div class="col-sm-3">
        <label class="form-label small fw-semibold">To</label>
        <input type="date" name="to" class="form-control" value="<%= to %>" />
      </div>
      <div class="col-sm-4">
        <label class="form-label small fw-semibold">User</label>
        <select name="user_id" class="form-select">
          <option value="">-- All users --</option>
          <% users.forEach(u => { %>
          <option value="<%= u.id %>" <%= selectedUser == u.id ? 'selected' : '' %>><%= u.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-sm-2">
        <button type="submit" class="btn btn-outline-primary w-100">
          <i class="bi bi-funnel me-1"></i>Filter
        </button>
      </div>
    </form>
  </div>
</div>

<!-- Summary table -->
<% if (summary.length) { %>
<div class="card border-0 shadow-sm mb-4">
  <div class="card-header bg-white fw-semibold">
    <i class="bi bi-person-lines-fill me-2 text-primary"></i>Hours by User
  </div>
  <div class="table-responsive">
    <table class="table table-sm align-middle mb-0">
      <thead class="table-light">
        <tr><th>User</th><th class="text-end">Total Hours</th></tr>
      </thead>
      <tbody>
        <% summary.forEach(s => { %>
        <tr>
          <td><%= s.user_name %></td>
          <td class="text-end fw-semibold"><%= parseFloat(s.total_hours).toFixed(2) %> h</td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<% } %>

<!-- Detailed breakdown -->
<% if (Object.keys(grouped).length === 0) { %>
<div class="text-center py-5 text-muted">
  <i class="bi bi-inbox" style="font-size:3rem"></i>
  <p class="mt-3">No data for the selected filters.</p>
</div>
<% } else { %>
  <% Object.values(grouped).forEach(client => { %>
  <div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-light">
      <i class="bi bi-building me-2 text-success"></i>
      <strong><%= client.name %></strong>
    </div>
    <div class="card-body p-0">
      <% Object.values(client.projects).forEach(proj => { %>
      <div class="border-bottom px-3 py-2 bg-white">
        <div class="fw-semibold text-muted small mb-2">
          <i class="bi bi-kanban me-1"></i><%= proj.name %>
        </div>
        <table class="table table-sm mb-0">
          <thead>
            <tr class="table-light">
              <th>User</th><th class="text-end">Hours</th>
            </tr>
          </thead>
          <tbody>
            <% const projTotal = proj.users.reduce((s, u) => s + u.hours, 0); %>
            <% proj.users.forEach(u => { %>
            <tr>
              <td><%= u.name %></td>
              <td class="text-end"><%= u.hours.toFixed(2) %> h</td>
            </tr>
            <% }) %>
            <tr class="table-light fw-bold">
              <td>Project total</td>
              <td class="text-end text-primary"><%= projTotal.toFixed(2) %> h</td>
            </tr>
          </tbody>
        </table>
      </div>
      <% }) %>
    </div>
  </div>
  <% }) %>
<% } %>

<%- include('../../partials/footer') %>
